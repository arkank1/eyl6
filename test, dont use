#!/usr/bin/env python

import rospy, sys, math
import numpy as np
from quadprog import solve_qp
from numpy import array, dot

from sensor_msgs.msg import LaserScan, Joy
from nav_msgs.msg import Odometry
from ackermann_msgs.msg import AckermannDriveStamped
from visualization_msgs.msg import Marker


# ──────────────────────────────────────────────
# Helper: wrap angle to (-pi, pi)
# ──────────────────────────────────────────────
def wrap_angle(a):
    return (a + math.pi) % (2.0 * math.pi) - math.pi


# ──────────────────────────────────────────────
# Main controller node
# ──────────────────────────────────────────────
class GapBarrier:

    # ------------------------------------------
    def __init__(self):

        rospy.init_node("GapWallFollow_node", anonymous=True)

        # --- ROS interface ---
        self._sub_scan  = rospy.Subscriber(rospy.get_param("~scan_topic",   "/scan"),  LaserScan, self._cb_scan,  queue_size=1)
        self._sub_odom  = rospy.Subscriber(rospy.get_param("~odom_topic",   "/odom"),  Odometry,  self._cb_odom,  queue_size=1)
        self._sub_joy   = rospy.Subscriber(rospy.get_param("~joy_topic",    "/joy"),   Joy,       self._cb_joy,   queue_size=1)
        self._pub_drive = rospy.Publisher( rospy.get_param("~drive_topic",  "/drive"), AckermannDriveStamped, queue_size=1)
        self._pub_mark  = rospy.Publisher( rospy.get_param("~marker_topic", "/best_gap_marker"), Marker, queue_size=1)

        # --- tuning knobs ---
        self._v_max       = rospy.get_param("~max_speed",            1.0)
        self._delta_max   = rospy.get_param("~max_steering_angle",   0.4189)
        self._v_target    = rospy.get_param("~target_speed",         1.5)
        self._d_stop      = rospy.get_param("~stop_distance",        0.6)
        self._d_tau       = rospy.get_param("~stop_distance_decay",  1.0)
        self._kp          = rospy.get_param("~kp_steering",          2.0)

        self._fov_deg     = rospy.get_param("~front_fov_deg",        180.0)
        self._r_max       = rospy.get_param("~max_lidar_range",      10.0)
        self._r_min       = rospy.get_param("~min_lidar_range",      0.05)
        self._bubble_r    = rospy.get_param("~safety_bubble_radius", 22)
        self._spd_window  = rospy.get_param("~front_speed_window",   25)
        self._danger_r    = rospy.get_param("~danger_distance",      1.6)

        self._btn_lb      = rospy.get_param("~lb_button_index",      4)
        self._btn_rb      = rospy.get_param("~rb_button_index",      5)
        self._ax_spd      = rospy.get_param("~speed_axis_index",     1)
        self._ax_steer    = rospy.get_param("~steering_axis_index",  3)

        # --- runtime state ---
        self._cur_vel     = 0.0
        self._joy_active  = False
        self._joy_v       = 0.0
        self._joy_delta   = 0.0


    # ------------------------------------------
    # Internal helpers
    # ------------------------------------------

    def _send_cmd(self, delta, v):
        msg = AckermannDriveStamped()
        msg.header.stamp    = rospy.Time.now()
        msg.drive.steering_angle = delta
        msg.drive.speed          = v
        self._pub_drive.publish(msg)

    def _send_marker(self, angle, dist):
        mk = Marker()
        mk.header.frame_id  = "laser"
        mk.header.stamp     = rospy.Time.now()
        mk.ns               = "best_gap_point"
        mk.id               = 0
        mk.type             = Marker.SPHERE
        mk.action           = Marker.ADD
        mk.pose.position.x  = dist * math.cos(angle)
        mk.pose.position.y  = dist * math.sin(angle)
        mk.pose.position.z  = 0.0
        mk.pose.orientation.w = 1.0
        mk.scale.x = mk.scale.y = mk.scale.z = 0.2
        mk.color.a = 1.0
        mk.color.r = 1.0
        mk.color.g = 0.0
        mk.color.b = 0.0
        self._pub_mark.publish(mk)

    def _clean_scan(self, raw):
        r = np.array(raw, dtype=np.float32)
        r[np.isnan(r)]       = 0.0
        r[np.isinf(r)]       = self._r_max
        r[r > self._r_max]   = self._r_max
        r[r < 0.0]           = 0.0

        N   = len(r)
        mid = N // 2
        hw  = int((self._fov_deg / 360.0) * N / 2.0)
        i0  = max(0, mid - hw)
        i1  = min(N, mid + hw)

        out = np.array(r[i0:i1], copy=True)

        K = 5
        if len(out) >= K:
            out = np.convolve(out, np.ones(K, dtype=np.float32) / K, mode='same')

        return out, i0, i1

    def _bubble(self, r):
        out = np.array(r, copy=True)
        hits = np.where((out > self._r_min) & (out < self._danger_r))[0]
        for idx in hits:
            a = max(0, idx - self._bubble_r)
            b = min(len(out), idx + self._bubble_r + 1)
            out[a:b] = 0.0
        return out

    def _max_gap(self, r):
        gs = ge = best_len = 0
        cur = None
        for i in range(len(r)):
            if r[i] > 0.0 and cur is None:
                cur = i
            elif r[i] == 0.0 and cur is not None:
                L = i - cur
                if L > best_len:
                    best_len, gs, ge = L, cur, i
                cur = None
        if cur is not None:
            L = len(r) - cur
            if L > best_len:
                gs, ge = cur, len(r)
        return gs, ge

    def _best_point(self, gs, ge, r):
        if ge <= gs:
            return len(r) // 2
        w  = ge - gs
        em = max(3, w // 5)
        ss = gs + em
        se = ge - em
        if se <= ss:
            return (gs + ge) // 2
        return (ss + se) // 2

    def getWalls(self, left_obstacles, right_obstacles, wl0, wr0, alpha):
        wl = wl0
        wr = wr0
        bl = 0.0
        br = 0.0
        return wl, wr, bl, br

    def _speed(self, r):
        mid = len(r) // 2
        hw  = self._spd_window
        seg = r[max(0, mid - hw) : min(len(r), mid + hw + 1)]
        valid = [x for x in seg if x > self._r_min]
        d_min = min(valid) if valid else self._r_max

        if   d_min < 0.3: v = 0.0
        elif d_min < 0.5: v = 0.6
        elif d_min < 0.8: v = 0.9
        else:             v = self._v_target

        return min(v, self._v_max), d_min


    # ------------------------------------------
    # ROS callbacks
    # ------------------------------------------

    def _cb_odom(self, msg):
        self._cur_vel = msg.twist.twist.linear.x

    def _cb_joy(self, msg):
        if len(msg.buttons) > self._btn_lb and msg.buttons[self._btn_lb] == 1:
            self._joy_active = True
            rospy.loginfo("Manual mode enabled")

        if len(msg.buttons) > self._btn_rb and msg.buttons[self._btn_rb] == 1:
            self._joy_active = False
            rospy.loginfo("Autonomous mode enabled")

        if self._joy_active:
            ax_v     = msg.axes[self._ax_spd]   if len(msg.axes) > self._ax_spd   else 0.0
            ax_delta = msg.axes[self._ax_steer]  if len(msg.axes) > self._ax_steer else 0.0
            self._joy_v     = self._v_max     * ax_v
            self._joy_delta = self._delta_max * ax_delta
            self._send_cmd(self._joy_delta, self._joy_v)

    def _cb_scan(self, msg):
        if self._joy_active:
            return

        r_clean, i0, i1 = self._clean_scan(msg.ranges)

        if len(r_clean) == 0:
            self._send_cmd(0.0, 0.0)
            return

        r_safe = self._bubble(r_clean)
        gs, ge = self._max_gap(r_safe)
        bp     = self._best_point(gs, ge, r_safe)

        bp_global = bp + i0
        theta     = msg.angle_min + bp_global * msg.angle_increment
        delta     = float(np.clip(2.0 * theta, -self._delta_max, self._delta_max))

        v, d_min = self._speed(r_clean)

        ratio = abs(delta) / self._delta_max
        v     = max(0.0, min(v * (1.0 - 0.8 * ratio), self._v_max))

        if d_min < 1.5: v = min(v, 0.5)
        if d_min < 1.0: v = min(v, 0.3)

        mid = len(r_clean) // 2
        fw  = r_clean[max(0, mid - 10) : min(len(r_clean), mid + 11)]
        if any(x < 0.7 for x in fw if x > self._r_min):
            v = 0.0

        self._send_cmd(delta, v)

        d_bp = r_clean[bp]
        a_bp = msg.angle_min + bp_global * msg.angle_increment
        self._send_marker(a_bp, d_bp)

        rospy.loginfo(
            "AUTO | gap=[%d,%d] best=%d target=%.3f steer=%.3f speed=%.3f dmin=%.3f",
            gs, ge, bp, theta, delta, v, d_min
        )


# ──────────────────────────────────────────────
if __name__ == '__main__':
    GapBarrier()
    rospy.sleep(0.1)
    rospy.spin()
