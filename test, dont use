class GapBarrier:
    def __init__(self):
       
        self.scan_topic = rospy.get_param("~scan_topic", "/scan")
        self.odom_topic = rospy.get_param("~odom_topic", "/odom")
        self.drive_topic = rospy.get_param("~drive_topic", "/drive")
        self.joy_topic = rospy.get_param("~joy_topic", "/joy")
        self.marker_topic = rospy.get_param("~marker_topic", "/best_gap_marker")

      
  
        self.max_speed = rospy.get_param("~max_speed", 1.0)
        self.max_steering_angle = rospy.get_param("~max_steering_angle", 0.4189)

        self.target_speed = rospy.get_param("~target_speed", 1.5)
        self.stop_distance = rospy.get_param("~stop_distance", 0.6)
        self.stop_distance_decay = rospy.get_param("~stop_distance_decay", 1.0)

        self.kp_steering = rospy.get_param("~kp_steering", 2.0)

        # LiDAR processing parameters
        self.front_fov_deg = rospy.get_param("~front_fov_deg", 180.0)
        self.max_lidar_range = rospy.get_param("~max_lidar_range", 10.0)
        self.min_lidar_range = rospy.get_param("~min_lidar_range", 0.05)
        self.safety_bubble_radius = rospy.get_param("~safety_bubble_radius", 22)
        self.front_speed_window = rospy.get_param("~front_speed_window", 25)
        self.danger_distance = rospy.get_param("~danger_distance", 1.6)

        # Joystick mapping
        self.lb_button_index = rospy.get_param("~lb_button_index", 4)
        self.rb_button_index = rospy.get_param("~rb_button_index", 5)
        self.speed_axis_index = rospy.get_param("~speed_axis_index", 1)
        self.steering_axis_index = rospy.get_param("~steering_axis_index", 3)

     
        self.vel = 0.0
        self.manual_mode = False
        self.manual_speed_command = 0.0
        self.manual_steering_command = 0.0

 
        self.scan_sub = rospy.Subscriber(
            self.scan_topic, LaserScan, self.lidar_callback, queue_size=1
        )
        self.odom_sub = rospy.Subscriber(
            self.odom_topic, Odometry, self.odom_callback, queue_size=1
        )
        self.joy_sub = rospy.Subscriber(
            self.joy_topic, Joy, self.joy_callback, queue_size=1
        )

        self.drive_pub = rospy.Publisher(
            self.drive_topic, AckermannDriveStamped, queue_size=1
        )
        self.marker_pub = rospy.Publisher(
            self.marker_topic, Marker, queue_size=1
        )

    # Optional function to pre-process LiDAR by considering only those LiDAR returns within a FOV in front of the vehicle
    def preprocess_lidar(self, ranges):
        lidar_ranges = np.array(ranges, dtype=np.float32)

        # Clean invalid values
        lidar_ranges[np.isnan(lidar_ranges)] = 0.0
        lidar_ranges[np.isinf(lidar_ranges)] = self.max_lidar_range

        # Limit only valid large readings
        lidar_ranges[lidar_ranges > self.max_lidar_range] = self.max_lidar_range
        lidar_ranges[lidar_ranges < 0.0] = 0.0

        num_ranges = len(lidar_ranges)
        center_index = num_ranges // 2
        half_window_size = int((self.front_fov_deg / 360.0) * num_ranges / 2.0)

        start_index = max(0, center_index - half_window_size)
        end_index = min(num_ranges, center_index + half_window_size)

        processed_ranges = np.array(lidar_ranges[start_index:end_index], copy=True)

        # Light smoothing to reduce noisy steering
        kernel_size = 5
        if len(processed_ranges) >= kernel_size:
            kernel = np.ones(kernel_size, dtype=np.float32) / float(kernel_size)
            processed_ranges = np.convolve(processed_ranges, kernel, mode='same')

        return processed_ranges, start_index, end_index

    # Optional function to find the maximum gap in front of the vehicle
    def find_max_gap(self, processed_ranges):
        best_gap_start = 0
        best_gap_end = 0
        longest_gap_length = 0

        current_gap_start = None

        for i in range(len(processed_ranges)):
            if processed_ranges[i] > 0.0 and current_gap_start is None:
                current_gap_start = i

            elif processed_ranges[i] == 0.0 and current_gap_start is not None:
                current_gap_length = i - current_gap_start
                if current_gap_length > longest_gap_length:
                    longest_gap_length = current_gap_length
                    best_gap_start = current_gap_start
                    best_gap_end = i
                current_gap_start = None

        if current_gap_start is not None:
            current_gap_length = len(processed_ranges) - current_gap_start
            if current_gap_length > longest_gap_length:
                best_gap_start = current_gap_start
                best_gap_end = len(processed_ranges)

        return best_gap_start, best_gap_end

    # Optional function to find the best direction of travel
    # start_i & end_i are the start and end indices of max-gap range, respectively
    # Returns index of best point in ranges
    def find_best_point(self, start_i, end_i, processed_ranges):
        if end_i <= start_i:
            return len(processed_ranges) // 2

        gap_width = end_i - start_i

        # Trim edges so the car does not hug the barriers
        edge_margin = max(3, gap_width // 5)

        safe_start = start_i + edge_margin
        safe_end = end_i - edge_margin

        if safe_end <= safe_start:
            return (start_i + end_i) // 2

        return (safe_start + safe_end) // 2

    # Optional function to set up and solve the optimization problem for parallel virtual barriers
    def getWalls(self, left_obstacles, right_obstacles, wl0, wr0, alpha):
        # Placeholder
        wl = wl0
        wr = wr0
        bl = 0.0
        br = 0.0
        return wl, wr, bl, br

    def apply_safety_bubble(self, processed_ranges):
        safe_ranges = np.array(processed_ranges, copy=True)

        close_indices = np.where(
            (safe_ranges > self.min_lidar_range) &
            (safe_ranges < self.danger_distance)
        )[0]

        for idx in close_indices:
            bubble_start = max(0, idx - self.safety_bubble_radius)
            bubble_end = min(len(safe_ranges), idx + self.safety_bubble_radius + 1)
            safe_ranges[bubble_start:bubble_end] = 0.0

        return safe_ranges

    def compute_speed_command(self, processed_ranges):
        center_index = len(processed_ranges) // 2
        window_half = self.front_speed_window

        window_start = max(0, center_index - window_half)
        window_end = min(len(processed_ranges), center_index + window_half + 1)

        front_ranges = processed_ranges[window_start:window_end]
        valid_front_ranges = [r for r in front_ranges if r > self.min_lidar_range]

        if len(valid_front_ranges) > 0:
            minimum_front_distance = min(valid_front_ranges)
        else:
            minimum_front_distance = self.max_lidar_range

        if minimum_front_distance < 0.3:
            speed_command = 0.0
        elif minimum_front_distance < 0.5:
            speed_command = 0.6
        elif minimum_front_distance < 0.8:
            speed_command = 0.9
        else:
            speed_command = self.target_speed

        speed_command = min(speed_command, self.max_speed)
        return speed_command, minimum_front_distance

    def publish_drive_command(self, steering_angle, speed):
        drive_message = AckermannDriveStamped()
        drive_message.header.stamp = rospy.Time.now()
        drive_message.drive.steering_angle = steering_angle
        drive_message.drive.speed = speed
        self.drive_pub.publish(drive_message)

    def publish_best_point_marker(self, angle, distance):
        marker = Marker()
        marker.header.frame_id = "laser"
        marker.header.stamp = rospy.Time.now()
        marker.ns = "best_gap_point"
        marker.id = 0
        marker.type = Marker.SPHERE
        marker.action = Marker.ADD

        marker.pose.position.x = distance * math.cos(angle)
        marker.pose.position.y = distance * math.sin(angle)
        marker.pose.position.z = 0.0
        marker.pose.orientation.w = 1.0

        marker.scale.x = 0.2
        marker.scale.y = 0.2
        marker.scale.z = 0.2

        marker.color.a = 1.0
        marker.color.r = 1.0
        marker.color.g = 0.0
        marker.color.b = 0.0

        self.marker_pub.publish(marker)

    def joy_callback(self, joy_msg):
        if len(joy_msg.buttons) > self.lb_button_index and joy_msg.buttons[self.lb_button_index] == 1:
            self.manual_mode = True
            rospy.loginfo("Manual mode enabled")

        if len(joy_msg.buttons) > self.rb_button_index and joy_msg.buttons[self.rb_button_index] == 1:
            self.manual_mode = False
            rospy.loginfo("Autonomous mode enabled")

        if self.manual_mode:
            speed_axis = 0.0
            steering_axis = 0.0

            if len(joy_msg.axes) > self.speed_axis_index:
                speed_axis = joy_msg.axes[self.speed_axis_index]

            if len(joy_msg.axes) > self.steering_axis_index:
                steering_axis = joy_msg.axes[self.steering_axis_index]

            self.manual_speed_command = self.max_speed * speed_axis
            self.manual_steering_command = self.max_steering_angle * steering_axis

            self.publish_drive_command(
                self.manual_steering_command,
                self.manual_speed_command
            )

    # This function is called whenever a new set of LiDAR data is received; bulk of your controller implementation should go here
    def lidar_callback(self, data):
        if self.manual_mode:
            return

        # Pre-process LiDAR data
        processed_ranges, start_index, end_index = self.preprocess_lidar(data.ranges)

        if len(processed_ranges) == 0:
            self.publish_drive_command(0.0, 0.0)
            return

        # Remove unsafe regions around all nearby barriers
        safe_ranges = self.apply_safety_bubble(processed_ranges)

        # Find the widest gap in front of vehicle
        max_gap_start, max_gap_end = self.find_max_gap(safe_ranges)

        # Find the best direction of travel
        best_point_index = self.find_best_point(max_gap_start, max_gap_end, safe_ranges)

        # Convert chosen point to steering angle
        best_point_global_index = best_point_index + start_index
        target_angle = data.angle_min + best_point_global_index * data.angle_increment

        steering_angle_command = 2.0 * target_angle
        steering_angle_command = np.clip(
            steering_angle_command,
            -self.max_steering_angle,
            self.max_steering_angle
        )

        # Speed control based on obstacles ahead
        speed_command, minimum_front_distance = self.compute_speed_command(processed_ranges)

        # Stronger speed reduction on sharp turns
        steering_ratio = abs(steering_angle_command) / self.max_steering_angle
        speed_command = speed_command * (1.0 - 0.8 * steering_ratio)
        speed_command = max(0.0, min(speed_command, self.max_speed))

        if minimum_front_distance < 1.5:
            speed_command = min(speed_command, 0.5)

        if minimum_front_distance < 1.0:
            speed_command = min(speed_command, 0.3)

        # Extra hard stop if something is very close directly ahead
        center_index = len(processed_ranges) // 2
        front_window = processed_ranges[
            max(0, center_index - 10):min(len(processed_ranges), center_index + 11)
        ]
        valid_front = [r for r in front_window if r > self.min_lidar_range]

        if len(valid_front) > 0 and min(valid_front) < 0.7:
            speed_command = 0.0

        # Publish steering and speed commands to the drive topic
        self.publish_drive_command(steering_angle_command, speed_command)

        # Marker for visualization
        best_point_distance = processed_ranges[best_point_index]
        best_point_angle = data.angle_min + best_point_global_index * data.angle_increment
        self.publish_best_point_marker(best_point_angle, best_point_distance)

        rospy.loginfo(
            "AUTO | gap=[%d,%d] best=%d target=%.3f steer=%.3f speed=%.3f dmin=%.3f",
            max_gap_start,
            max_gap_end,
            best_point_index,
            target_angle,
            steering_angle_command,
            speed_command,
            minimum_front_distance
        )

    # Odometry callback
    def odom_callback(self, odom_msg):
        self.vel = odom_msg.twist.twist.linear.x


