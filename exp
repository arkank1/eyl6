#!/usr/bin/env python
import sys
import math
import rospy
import numpy as np

from quadprog import solve_qp
from sensor_msgs.msg import LaserScan, Joy
from ackermann_msgs.msg import AckermannDriveStamped
from nav_msgs.msg import Odometry


class GapBarrier:
    def __init__(self):
        # state
        self.vel              = 0.0
        self.manual_mode      = False
        self.manual_speed     = 0.0
        self.manual_steer     = 0.0

        # joystick
        self.lb_button_index     = rospy.get_param('lb_button_index',     4)
        self.rb_button_index     = rospy.get_param('rb_button_index',     5)
        self.speed_axis_index    = rospy.get_param('speed_axis_index',    1)
        self.steering_axis_index = rospy.get_param('steering_axis_index', 3)

        # speed and steering
        self.max_speed          = rospy.get_param('max_speed',          1.0)
        self.max_steering_angle = rospy.get_param('max_steering_angle', 0.4189)
        self.target_speed       = rospy.get_param('target_speed',       1.5)

        # lidar
        self.front_fov_deg        = rospy.get_param('front_fov_deg',        180.0)
        self.max_lidar_range      = rospy.get_param('max_lidar_range',      10.0)
        self.min_lidar_range      = rospy.get_param('min_lidar_range',      0.05)
        self.safety_bubble_radius = rospy.get_param('safety_bubble_radius', 22)
        self.front_speed_window   = rospy.get_param('front_speed_window',   25)
        self.danger_distance      = rospy.get_param('danger_distance',      1.6)

        # subscribers and publishers
        self.drive_pub = rospy.Publisher(rospy.get_param('drive_topic', '/drive'), AckermannDriveStamped, queue_size=1)
        self.odom_sub  = rospy.Subscriber(rospy.get_param('odom_topic', '/odom'),  Odometry,  self.odom_callback,  queue_size=1)
        self.joy_sub   = rospy.Subscriber(rospy.get_param('joy_topic',  '/joy'),   Joy,       self.joy_callback,   queue_size=1)
        self.scan_sub  = rospy.Subscriber(rospy.get_param('scan_topic', '/scan'),  LaserScan, self.lidar_callback, queue_size=1)


    def getWalls(self, left_obstacles, right_obstacles, wl0, wr0, alpha):
        return wl0, wr0, 0.0, 0.0


    def apply_safety_bubble(self, ranges):
        out = np.array(ranges, copy=True)
        hits = np.where((out > self.min_lidar_range) & (out < self.danger_distance))[0]
        for i in hits:
            lo = max(0, i - self.safety_bubble_radius)
            hi = min(len(out), i + self.safety_bubble_radius + 1)
            out[lo:hi] = 0.0
        return out


    def find_max_gap(self, ranges):
        gs = ge = best = 0
        cur = None
        for i in range(len(ranges)):
            if ranges[i] > 0.0 and cur is None:
                cur = i
            elif ranges[i] == 0.0 and cur is not None:
                n = i - cur
                if n > best:
                    best, gs, ge = n, cur, i
                cur = None
        if cur is not None:
            n = len(ranges) - cur
            if n > best:
                gs, ge = cur, len(ranges)
        return gs, ge


    def find_best_point(self, gs, ge, ranges):
        if ge <= gs:
            return len(ranges) // 2
        margin = max(3, (ge - gs) // 5)
        ss = gs + margin
        se = ge - margin
        if se <= ss:
            return (gs + ge) // 2
        return (ss + se) // 2


    def odom_callback(self, odom_msg):
        self.vel = odom_msg.twist.twist.linear.x


    def joy_callback(self, joy_msg):
        if len(joy_msg.buttons) > self.lb_button_index and joy_msg.buttons[self.lb_button_index] == 1:
            self.manual_mode = True

        if len(joy_msg.buttons) > self.rb_button_index and joy_msg.buttons[self.rb_button_index] == 1:
            self.manual_mode = False

        if self.manual_mode:
            spd   = joy_msg.axes[self.speed_axis_index]    if len(joy_msg.axes) > self.speed_axis_index    else 0.0
            steer = joy_msg.axes[self.steering_axis_index] if len(joy_msg.axes) > self.steering_axis_index else 0.0
            self.manual_speed = self.max_speed          * spd
            self.manual_steer = self.max_steering_angle * steer
            self._send(self.manual_steer, self.manual_speed)


    def lidar_callback(self, data):
        if self.manual_mode:
            return

        # build range array and clip to valid values
        r = np.array(data.ranges, dtype=np.float32)
        r[np.isnan(r)] = 0.0
        r[np.isinf(r)] = self.max_lidar_range
        r[r > self.max_lidar_range] = self.max_lidar_range
        r[r < 0.0] = 0.0

        # restrict to front fov
        N   = len(r)
        mid = N // 2
        hw  = int((self.front_fov_deg / 360.0) * N / 2.0)
        i0  = max(0, mid - hw)
        i1  = min(N, mid + hw)
        r   = np.array(r[i0:i1], copy=True)
        mid = len(r) // 2  # recalculate mid relative to the trimmed array

        if len(r) == 0:
            self._send(0.0, 0.0)
            return

        # smooth to reduce steering noise
        k = 3
        if len(r) >= k:
            r = np.convolve(r, np.ones(k, dtype=np.float32) / k, mode='same')

        # zero out readings near obstacles to create bubble
        r = self.apply_safety_bubble(r)

        # find largest free gap and best heading within it
        gs, ge   = self.find_max_gap(r)
        bp       = self.find_best_point(gs, ge, r)
        bp_glob  = bp + i0
        angle    = data.angle_min + bp_glob * data.angle_increment

        # compute and clip steering command
        steer = float(np.clip(2.0 * angle, -self.max_steering_angle, self.max_steering_angle))

        # compute speed from front clearance
        hw2   = self.front_speed_window
        seg   = r[max(0, mid - hw2) : min(len(r), mid + hw2 + 1)]
        valid = [x for x in seg if x > self.min_lidar_range]
        d_min = min(valid) if valid else self.max_lidar_range

        if d_min < 0.3:
            spd = 0.0
        elif d_min < 0.5:
            spd = 0.6
        elif d_min < 0.8:
            spd = 0.9
        else:
            spd = self.target_speed

        spd = min(spd, self.max_speed)

        # slow down proportionally on sharp turns
        spd = spd * (1.0 - 0.8 * abs(steer) / self.max_steering_angle)
        spd = max(0.0, min(spd, self.max_speed))

        if d_min < 1.5:
            spd = min(spd, 0.5)
        if d_min < 1.0:
            spd = min(spd, 0.3)

        # emergency stop
        fw = r[max(0, mid - 10) : min(len(r), mid + 11)]
        if any(x < 0.7 for x in fw if x > self.min_lidar_range):
            spd = 0.0

        self._send(steer, spd)


    def _send(self, steer, spd):
        msg = AckermannDriveStamped()
        msg.header.stamp          = rospy.Time.now()
        msg.drive.steering_angle  = steer
        msg.drive.speed           = spd
        self.drive_pub.publish(msg)


def main(args):
    rospy.init_node('GapWallFollow_node', anonymous=True)
    GapBarrier()
    rospy.sleep(0.1)
    rospy.spin()


if __name__ == '__main__':
    main(sys.argv)
